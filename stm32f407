```cpp
#include <Wire.h>


#define MPU_ADDR 0x68

// I2C Pin Definitions for STM32F407
#define I2C_SDA PB7
#define I2C_SCL PB6

// OFFSETS
float ax_offset = 0, ay_offset = 0, az_offset = 0;
float gx_offset = 0, gy_offset = 0, gz_offset = 0;

// RAW & SCALED DATA
float ax, ay, az;
float gx, gy, gz;

// MADGWICK (6-DOF) State
float q0 = 1.0f, q1 = 0.0f, q2 = 0.0f, q3 = 0.0f;
float beta = 0.04f; 
unsigned long lastUpdate = 0;

// SMOOTHING (EMA Filters)
float ema_in = 0.1f;   
float ema_out = 0.05f; 
float f_ax = 0, f_ay = 0, f_az = 0, f_gx = 0, f_gy = 0, f_gz = 0;
float f_roll = 0, f_pitch = 0, f_yaw = 0;
bool first_loop = true;

void readMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 14);

  if (Wire.available() >= 14) {
    int16_t ax_raw = Wire.read() << 8 | Wire.read();
    int16_t ay_raw = Wire.read() << 8 | Wire.read();
    int16_t az_raw = Wire.read() << 8 | Wire.read();
    Wire.read(); Wire.read();
    int16_t gx_raw = Wire.read() << 8 | Wire.read();
    int16_t gy_raw = Wire.read() << 8 | Wire.read();
    int16_t gz_raw = Wire.read() << 8 | Wire.read();

    // Scale factors for MPU-9250 (+/- 2g, +/- 250dps)
    ax = ax_raw / 16384.0f;
    ay = ay_raw / 16384.0f;
    az = az_raw / 16384.0f;
    gx = gx_raw / 131.0f;
    gy = gy_raw / 131.0f;
    gz = gz_raw / 131.0f;

    ax -= ax_offset; ay -= ay_offset; az -= az_offset;
    gx -= gx_offset; gy -= gy_offset; gz -= gz_offset;
  }
}

void calibrateMPU() {
  int samples = 1000;
  float ax_sum = 0, ay_sum = 0, az_sum = 0;
  float gx_sum = 0, gy_sum = 0, gz_sum = 0;

  for (int i = 0; i < samples; i++) {
    readMPU();
    ax_sum += ax; ay_sum += ay; az_sum += az;
    gx_sum += gx; gy_sum += gy; gz_sum += gz;
    delay(2);
  }
  ax_offset = ax_sum / samples;
  ay_offset = ay_sum / samples;
  az_offset = (az_sum / samples) - 1.0f;
  gx_offset = gx_sum / samples;
  gy_offset = gy_sum / samples;
  gz_offset = gz_sum / samples;
}

void setup() {
  
  Serial.begin(115200);

  // STM32 I2C Initialization
  Wire.setSDA(I2C_SDA);
  Wire.setSCL(I2C_SCL);
  Wire.begin();
  Wire.setClock(400000); // 400khz

  // Wake up MPU
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);
  Wire.write(0x00);
  Wire.endTransmission();

  // Low Pass Filter ~20Hz
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x1A);
  Wire.write(0x04); 
  Wire.endTransmission();

  Serial.println("STM32F407 AHRS Starting...");
  delay(1000);
  calibrateMPU();
  
  lastUpdate = micros();
}

void madgwickUpdate() {
  unsigned long now = micros();
  float dt = (now - lastUpdate) / 1000000.0f;
  lastUpdate = now;

  float recipNorm;
  float s0, s1, s2, s3;
  float qDot1, qDot2, qDot3, qDot4;
  float _2q0, _2q1, _2q2, _2q3, _4q0, _4q1, _4q2, _8q1, _8q2, q0q0, q1q1, q2q2, q3q3;

  float gx_rad = gx * 0.0174533f;
  float gy_rad = gy * 0.0174533f;
  float gz_rad = gz * 0.0174533f;

  qDot1 = 0.5f * (-q1 * gx_rad - q2 * gy_rad - q3 * gz_rad);
  qDot2 = 0.5f * (q0 * gx_rad + q2 * gz_rad - q3 * gy_rad);
  qDot3 = 0.5f * (q0 * gy_rad - q1 * gz_rad + q3 * gx_rad);
  qDot4 = 0.5f * (q0 * gz_rad + q1 * gy_rad - q2 * gx_rad);

  if (!((ax == 0.0f) && (ay == 0.0f) && (az == 0.0f))) {
    recipNorm = 1.0f / sqrtf(ax * ax + ay * ay + az * az);
    float ax_n = ax * recipNorm;
    float ay_n = ay * recipNorm;
    float az_n = az * recipNorm;

    _2q0 = 2.0f * q0; _2q1 = 2.0f * q1; _2q2 = 2.0f * q2; _2q3 = 2.0f * q3;
    _4q0 = 4.0f * q0; _4q1 = 4.0f * q1; _4q2 = 4.0f * q2;
    _8q1 = 8.0f * q1; _8q2 = 8.0f * q2;
    q0q0 = q0 * q0; q1q1 = q1 * q1; q2q2 = q2 * q2; q3q3 = q3 * q3;

    s0 = _4q0 * q2q2 + _2q2 * ax_n + _4q0 * q1q1 - _2q1 * ay_n;
    s1 = _4q1 * q3q3 - _2q3 * ax_n + 4.0f * q0q0 * q1 - _2q0 * ay_n - _4q1 + _8q1 * q1q1 + _8q1 * q2q2 + _4q1 * az_n;
    s2 = 4.0f * q0q0 * q2 + _2q0 * ax_n + _4q2 * q3q3 - _2q3 * ay_n - _4q2 + _8q2 * q1q1 + _8q2 * q2q2 + _4q2 * az_n;
    s3 = 4.0f * q1q1 * q3 - _2q1 * ax_n + 4.0f * q2q2 * q3 - _2q2 * ay_n;

    recipNorm = 1.0f / sqrtf(s0 * s0 + s1 * s1 + s2 * s2 + s3 * s3);
    s0 *= recipNorm; s1 *= recipNorm; s2 *= recipNorm; s3 *= recipNorm;

    qDot1 -= beta * s0; qDot2 -= beta * s1; qDot3 -= beta * s2; qDot4 -= beta * s3;
  }

  q0 += qDot1 * dt; q1 += qDot2 * dt; q2 += qDot3 * dt; q3 += qDot4 * dt;
  recipNorm = 1.0f / sqrtf(q0 * q0 + q1 * q1 + q2 * q2 + q3 * q3);
  q0 *= recipNorm; q1 *= recipNorm; q2 *= recipNorm; q3 *= recipNorm;
}

void loop() {
  readMPU();

  if (first_loop) {
    f_ax = ax; f_ay = ay; f_az = az;
    f_gx = gx; f_gy = gy; f_gz = gz;
  } else {
    f_ax = (ema_in * ax) + ((1.0f - ema_in) * f_ax);
    f_ay = (ema_in * ay) + ((1.0f - ema_in) * f_ay);
    f_az = (ema_in * az) + ((1.0f - ema_in) * f_az);
    f_gx = (ema_in * gx) + ((1.0f - ema_in) * f_gx);
    f_gy = (ema_in * gy) + ((1.0f - ema_in) * f_gy);
    f_gz = (ema_in * gz) + ((1.0f - ema_in) * f_gz);
  }

  ax = f_ax; ay = f_ay; az = f_az;
  gx = f_gx; gy = f_gy; gz = f_gz;

  madgwickUpdate();

  float roll  = atan2f(2.0f * (q0 * q1 + q2 * q3), 1.0f - 2.0f * (q1 * q1 + q2 * q2)) * 57.2958f;
  float pitch = asinf(2.0f * (q0 * q2 - q3 * q1)) * 57.2958f;
  float yaw   = atan2f(2.0f * (q0 * q3 + q1 * q2), 1.0f - 2.0f * (q2 * q2 + q3 * q3)) * 57.2958f;

  if (first_loop) {
    f_roll = roll; f_pitch = pitch; f_yaw = yaw;
    first_loop = false;
  } else {
    f_roll  = (ema_out * roll)  + ((1.0f - ema_out) * f_roll);
    f_pitch = (ema_out * pitch) + ((1.0f - ema_out) * f_pitch);
    f_yaw   = (ema_out * yaw)   + ((1.0f - ema_out) * f_yaw);
  }

  Serial.print(f_roll); Serial.print(",");
  Serial.print(f_pitch); Serial.print(",");
  Serial.println(f_yaw);

  delay(2); 
}

